   CONTROL(MANUAL) +
   SERVTYPE(SERVER) +
   STARTCMD('+MQ_INSTALL_PATH+\bin\amqp.bat') +
   STARTARG('start -m +QMNAME+ -d "+MQ_Q_MGR_DATA_PATH+\." -g "+MQ_DATA_PATH+\."') +
   STOPCMD('+MQ_INSTALL_PATH+\bin64\endmqsde.exe') +
